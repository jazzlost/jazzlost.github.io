---
import PostCard from '@/components/PostCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getAllTags, getPublishedPosts, getTagPath } from '@/lib/posts';
import { site } from '@/lib/site';

const posts = await getPublishedPosts();
const featuredPosts = posts.slice(0, 6);
const tags = getAllTags(posts);
---

<BaseLayout>
  <section class="container home-layout">
    <div class="home-main">
      <div class="section-header">
        <div>
          <p class="eyebrow">Latest</p>
          <h2>最新文章</h2>
        </div>
        <a href="/archive/">View archive</a>
      </div>
      <div class="post-grid">
        {featuredPosts.map((post) => <PostCard post={post} />)}
      </div>
    </div>

    <aside class="sidebar" aria-label="Blog profile and tags">
      <ul class="tag-list sidebar-tags" aria-label="Tags">
        {tags.map((tag) => <li><a class="tag" href={getTagPath(tag.name)}>{tag.name}</a></li>)}
      </ul>
      <hr />
      <img class="sidebar-image" src={site.sidebarImage} alt="" loading="lazy" />
      <div class="sidebar-bio">
        <h2>{site.title}</h2>
        {site.sidebarLines.map((line) => <p>{line}</p>)}
      </div>
    </aside>
  </section>
</BaseLayout>

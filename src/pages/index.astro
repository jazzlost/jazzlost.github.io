---
import PostCard from '@/components/PostCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getAllTags, getPublishedPosts, getTagPath } from '@/lib/posts';
import { site } from '@/lib/site';

const posts = await getPublishedPosts();
const featuredPosts = posts.slice(0, 6);
const tags = getAllTags(posts);
---

<BaseLayout>
  <section class="container hero">
    <div>
      <p class="eyebrow">Research notes</p>
      <h1>{site.title}</h1>
      <p class="lead">{site.description}</p>
      <ul class="topic-list" aria-label="Topics">
        {site.topics.map((topic) => <li><span class="pill">{topic}</span></li>)}
      </ul>
    </div>

    <aside class="sidebar" aria-label="Blog profile and tags">
      <ul class="tag-list sidebar-tags" aria-label="Tags">
        {tags.map((tag) => <li><a class="tag" href={getTagPath(tag.name)}>{tag.name}</a></li>)}
      </ul>
      <hr />
      <img class="sidebar-image" src={site.sidebarImage} alt="" loading="lazy" />
      <div class="sidebar-bio">
        <h2>{site.title}</h2>
        {site.sidebarLines.map((line) => <p>{line}</p>)}
      </div>
    </aside>
  </section>

  <section class="container section">
    <div class="section-header">
      <div>
        <p class="eyebrow">Latest</p>
        <h2>最新文章</h2>
      </div>
      <a href="/archive/">View archive</a>
    </div>
    <div class="post-grid">
      {featuredPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>

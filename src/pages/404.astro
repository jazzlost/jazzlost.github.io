---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="404" description="页面不存在">
  <section class="container narrow section">
    <p class="eyebrow">404</p>
    <h1>页面不存在</h1>
    <p class="lead">这个地址没有对应的新页面。可以从归档或搜索重新进入。</p>
    <p><a href="/archive/">查看归档</a> · <a href="/search/">搜索文章</a></p>
  </section>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatDate, getPostsByYear, getPostPath, getPublishedPosts } from '@/lib/posts';

const posts = await getPublishedPosts();
const postsByYear = getPostsByYear(posts);
---

<BaseLayout title="Archive" description="jazzlost 文章归档">
  <section class="container narrow section">
    <p class="eyebrow">Archive</p>
    <h1>文章归档</h1>
    <p class="lead">按年份浏览全部公开笔记。</p>
  </section>
  <section class="container narrow section">
    {postsByYear.map(([year, yearPosts]) => (
      <div class="archive-year">
        <h2>{year}</h2>
        {yearPosts.map((post) => (
          <a class="archive-item" href={getPostPath(post)}>
            <span class="meta">{formatDate(post.data.date)}</span>
            <span>{post.data.title}</span>
          </a>
        ))}
      </div>
    ))}
  </section>
</BaseLayout>

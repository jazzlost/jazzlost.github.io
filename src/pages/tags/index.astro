---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getAllTags, getPublishedPosts, getTagPath } from '@/lib/posts';

const posts = await getPublishedPosts();
const tags = getAllTags(posts);
---

<BaseLayout title="Tags" description="jazzlost 标签索引">
  <section class="container narrow section">
    <p class="eyebrow">Tags</p>
    <h1>标签索引</h1>
    <p class="lead">用主题线索重新进入旧文章。</p>
    <ul class="tag-list">
      {tags.map((tag) => <li><a class="tag" href={getTagPath(tag.name)}>{tag.name} · {tag.count}</a></li>)}
    </ul>
  </section>
</BaseLayout>
